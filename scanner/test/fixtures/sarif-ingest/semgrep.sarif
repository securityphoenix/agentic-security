{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "semgrep",
          "version": "1.50.0",
          "rules": [
            {
              "id": "javascript.express.security.audit.express-cookie-session-no-httponly",
              "shortDescription": { "text": "Cookie missing HttpOnly flag" },
              "fullDescription": { "text": "Cookies should be marked HttpOnly to prevent JavaScript access" },
              "properties": { "tags": ["CWE-1004", "security"] },
              "helpUri": "https://cwe.mitre.org/data/definitions/1004.html"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "javascript.express.security.audit.express-cookie-session-no-httponly",
          "level": "warning",
          "message": { "text": "Cookie missing HttpOnly flag at /admin endpoint" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/auth.js" },
                "region": { "startLine": 42, "startColumn": 4 }
              }
            }
          ]
        }
      ]
    }
  ]
}
