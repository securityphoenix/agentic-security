{
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gitleaks",
          "version": "8.18.0",
          "rules": [
            {
              "id": "aws-access-token",
              "shortDescription": { "text": "AWS Access Key" },
              "properties": { "tags": ["CWE-798", "secret"] }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "aws-access-token",
          "level": "error",
          "message": { "text": "Hardcoded AWS access key ID" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/auth.js" },
                "region": { "startLine": 41, "startColumn": 16 }
              }
            }
          ]
        }
      ]
    }
  ]
}
