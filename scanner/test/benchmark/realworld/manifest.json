          "CWE89": "sql-injection",
          "CWE90": "ldap-injection",
          "CWE94": "code-injection",
          "CWE113": "header-hardening",
          "CWE256": "hardcoded-secret",
          "CWE259": "hardcoded-secret",
          "CWE315": "data-exposure",
          "CWE319": "insecure-http",
          "CWE321": "hardcoded-secret",
          "CWE327": "weak-crypto",
          "CWE328": "weak-crypto",
          "CWE329": "weak-rng",
          "CWE330": "weak-rng",
          "CWE336": "weak-rng",
          "CWE338": "weak-rng",
          "CWE501": "trust-boundary",
          "CWE502": "insecure-deserialization",
          "CWE601": "open-redirect",
          "CWE611": "xxe",
          "CWE614": "header-hardening",
          "CWE643": "xpath-injection",
          "CWE798": "hardcoded-secret",
          "CWE1004": "header-hardening"
        }
      },
      "_targetingRationale": "SARD/Juliet test cases pair vulnerable bad() + mitigated good*() functions in the same file. Strict per-method scoring (which method did the scanner fire on?) requires AST analysis to distinguish their spans \u2014 the regex engine fires file-level. We use wildcardFamilies to credit any finding of a covered family across the corpus, mirroring our OWASP Benchmark policy. Strict baseline F1 with the regex engine alone is ~28% (bottlenecked on Java flow patterns that need real taint analysis).",
