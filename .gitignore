scanner/node_modules/

# scanner/dist/agentic-security.mjs IS tracked in git on purpose: the
# reusable .github/workflows/scan.yml fetches it from raw.githubusercontent.com
# at HEAD-of-main so downstream CI users don't need to install anything to use
# the action. Tests run against scanner/src/ directly via the Node test runner.
# (Premortem 4R-2: the previous gitignore comment claimed dist was "Not
# committed" — incorrect. The file IS committed; only the rest of dist/ is
# transient build output we don't care to track.)
scanner/dist/*
!scanner/dist/agentic-security.mjs
!scanner/dist/agentic-security.mjs.sha256
!scanner/dist/calibration-seed.json
# Ignore all .agentic-security/ dirs at any depth. For the root one,
# ignore all contents but un-ignore the config files that belong in VCS.
**/.agentic-security/
!/.agentic-security/
/.agentic-security/*
!/.agentic-security/rules.yml
!/.agentic-security/license-policy.yml
*.log
.DS_Store

# Real-world benchmark cache — external repos cloned on demand, never committed.
# Keyed by {app}-{sha} so updating the manifest invalidates only that entry.
scanner/test/benchmark/realworld/.bench-cache/

# CHANGELOG.md is copied into scanner/ at npm publish (prepublishOnly) so it
# ships in the package; the canonical copy lives at the repo root.
scanner/CHANGELOG.md

# OWASP LLM Top 10 goat benchmark — external repos cloned on demand.
scanner/test/benchmark/llm-goats/.cache/

# Python caches from compliance helper scripts (scripts/{nist,owasp-asvs,pci,soc2}/).
__pycache__/

# Compliance attestation outputs are generated per-project, not committed.
nist-ai-600-1-attestation.*
owasp-asvs-attestation.*
pci-dss-attestation.*
soc2-attestation.*

# Per-scan output files written into project's .agentic-security/ dir.
findings.json
findings.sarif
findings.csv
last-scan.json

# HTML reports generated by /show-findings
reports/findings-*.html
