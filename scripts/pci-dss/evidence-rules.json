{
  "_doc": "PCI-DSS 4.0 code-testable controls. Pure-organisational controls (3.4 'documented procedures') are excluded. Edit/extend per project.",
  "controls": [
    {
      "id": "1.4.5", "title": "Internal IP / network info redacted from external responses",
      "terms": ["redactIp", "obscure_internal", "x-internal-network"]
    },
    {
      "id": "2.2.5", "title": "Insecure services (telnet, ftp, plain http) not enabled",
      "terms": ["telnet", "ftp_server", "http://localhost"]
    },
    {
      "id": "3.5.1", "title": "PAN encrypted using strong cryptography",
      "terms": ["AES-256", "AES_256", "encrypt_pan", "encryptCardNumber"]
    },
    {
      "id": "4.2.1", "title": "TLS 1.2+ enforced on transmission of cardholder data",
      "terms": ["TLS_1_2", "TLSv1.2", "TLSv1_2", "minVersion: 'TLSv1.2'", "ssl_min_version"]
    },
    {
      "id": "6.2.4", "title": "Software-development includes secure coding practices",
      "manifest_deps": ["eslint-plugin-security", "bandit", "semgrep"],
      "paths": [".github/workflows/*security*", "**/.eslintrc*"]
    },
    {
      "id": "6.4.3", "title": "Public-facing web apps protected with WAF / equivalent",
      "manifest_deps": ["express-rate-limit", "fastify-rate-limit", "helmet", "django-ratelimit"],
      "imports": ["helmet", "express-rate-limit", "fastify-rate-limit"]
    },
    {
      "id": "8.3.1", "title": "Strong authentication for all user accounts",
      "manifest_deps": ["bcrypt", "argon2", "passport", "passport-jwt", "@auth0/auth0-spa-js"],
      "imports": ["bcrypt", "argon2", "passport"]
    },
    {
      "id": "8.3.6", "title": "Account lockout after ≤6 invalid logins",
      "terms": ["MAX_LOGIN_ATTEMPTS", "lockout", "account_locked", "rate_limit_login"]
    },
    {
      "id": "8.5.1", "title": "MFA for non-console admin access",
      "manifest_deps": ["speakeasy", "pyotp", "@simplewebauthn/server"],
      "terms": ["TOTP", "WebAuthn", "MFA"]
    },
    {
      "id": "10.2.1", "title": "Audit log of access to cardholder data",
      "imports": ["winston", "pino", "structlog", "loguru"],
      "terms": ["audit_log", "audit.log", "logAccess", "AccessLog"]
    },
    {
      "id": "10.4.2", "title": "Time synchronization (NTP) configured",
      "paths": ["**/ntp.conf", ".github/workflows/*time*"],
      "terms": ["chrony", "ntpd", "time.sync"]
    },
    {
      "id": "11.3.1.1", "title": "Internal vulnerability scanning quarterly",
      "manifest_deps": ["snyk", "audit-ci", "npm-audit-resolver"],
      "paths": [".github/workflows/*security*.yml", ".snyk"]
    }
  ]
}
