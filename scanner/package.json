{
  "name": "@clearcapabilities/agentic-security-scanner",
  "version": "0.1.0",
  "description": "Scanner engine for the agentic-security Claude Code plugin (SAST + SCA + Secrets).",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "agentic-security": "dist/agentic-security.mjs"
  },
  "exports": {
    ".": "./src/index.js",
    "./engine": "./src/engine.js",
    "./sast": "./src/sast/index.js",
    "./sca": "./src/sca/index.js",
    "./secrets": "./src/secrets/index.js",
    "./report": "./src/report/index.js"
  },
  "files": [
    "src/",
    "bin/",
    "dist/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "fast-glob": "^3.3.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.3"
  },
  "scripts": {
    "build": "ncc build bin/agentic-security.js -o dist --minify && mv dist/index.js dist/agentic-security.mjs && rm -f dist/package.json && chmod +x dist/agentic-security.mjs",
    "test": "node --test test/smoke.test.js",
    "smoke": "node bin/agentic-security.js scan test/fixtures/vulnerable-js"
  },
  "author": "Ross Young <ross@clearcapabilities.com>",
  "license": "SEE LICENSE IN LICENSE"
}
