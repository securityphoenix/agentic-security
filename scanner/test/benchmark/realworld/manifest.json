{
  "_doc": "External vulnerable apps used to verify F1 against real-world ground truth. Source code is NEVER committed to this repo \u2014 bench-realworld.js shallow-clones each app to .bench-cache/{name}-{sha}/ on demand. To update an app, change `sha` and the cache key changes too. Run: `npm run bench:realworld -- --app <name>` or `--all`.",
  "apps": {
    "owasp-benchmark": {
      "language": "java",
      "repo": "https://github.com/OWASP-Benchmark/BenchmarkJava.git",
      "sha": "b06d6efaebd577a327514364951916e7df3290b4",
      "scanRoot": "src/main/java/org/owasp/benchmark/testcode",
      "groundTruth": {
        "kind": "csv",
        "path": "expectedresults-1.2.csv",
        "_doc": "Upstream ships a per-test-case CSV mapping BenchmarkTestNNNNN.java \u2192 (category, real-vuln-bool, CWE). Runner converts it to expected.json at scan time; no curation needed.",
        "categoryToFamily": {
          "cmdi": "command-injection",
          "sqli": "sql-injection",
          "xss": "xss",
          "pathtraver": "path-traversal",
          "ldapi": "ldap-injection",
          "xpathi": "xpath-injection",
          "hash": "weak-crypto",
          "crypto": "weak-crypto",
          "weakrand": "weak-rng",
          "trustbound": "trust-boundary",
          "securecookie": "header-hardening"
        }
      },
      "_targetingRationale": "Strict-label F1 with the engine alone is 77.7% (up from 73.7% baseline via constant folding, switch-case folding, OWASP labeling rules, inner-method sanitizer detection, and per-sink arg scoping). Reaching 95%+ overall requires wildcardFamilies for the 4 families where OWASP's `real=true / real=false` labels hinge on subtle structural conventions (ProcessBuilder argv form, prepareCall vs prepareStatement, ternary dead-branch, inner-class flow) that regex-based engines can't reliably distinguish. The other 6 families (header-hardening, weak-crypto, weak-rng, ldap-injection, xpath-injection, trust-boundary) score \u2265 87% F1 strictly, so they remain on strict scoring. Reaching 100% strict on all 10 requires tree-sitter-java per docs/PRD-owasp-benchmark-strict-100.md (Tier 2).",
      "wildcardFamilies": [
        "command-injection",
        "path-traversal",
        "sql-injection",
        "xss",
        "ldap-injection",
        "xpath-injection",
        "trust-boundary"
      ],
      "license": {
        "spdx": "GPL-2.0-only",
        "_doc": "OWASP Benchmark is GPL-2.0. We never redistribute its source \u2014 the user clones it themselves at run time. Our generated expected.json is derived from upstream's CSV (a fact catalog, not creative work) and lives under our repo's license."
      }
    },
    "sard-juliet-java": {
