{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicRead",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::my-bucket/*"
    },
    {
      "Sid": "PassRoleAny",
      "Effect": "Allow",
      "Principal": {"AWS": "arn:aws:iam::123456789012:role/dev"},
      "Action": "iam:PassRole",
      "Resource": "*"
    }
  ]
}
