{
  "_doc": "SOC 2 Common Criteria — code-testable subset. Pure-organisational CCs (board oversight, vendor management) are excluded. Edit/extend per project.",
  "controls": [
    {
      "id": "CC6.1", "title": "Logical access controls — RBAC / ABAC enforced",
      "manifest_deps": ["accesscontrol", "casbin", "@casl/ability", "django-guardian"],
      "imports": ["casbin", "@casl/ability"],
      "terms": ["RBAC", "@RolesAllowed", "permit_if", "AuthGuard"]
    },
    {
      "id": "CC6.2", "title": "MFA for privileged users",
      "manifest_deps": ["speakeasy", "pyotp", "@simplewebauthn/server"],
      "terms": ["TOTP", "WebAuthn", "MFA"]
    },
    {
      "id": "CC6.3", "title": "Access reviews logged",
      "terms": ["accessReview", "access_review", "permission_audit"]
    },
    {
      "id": "CC6.6", "title": "Logical access removed promptly on termination",
      "terms": ["deactivateUser", "revokeAccess", "user.deactivate"]
    },
    {
      "id": "CC6.7", "title": "Encryption of data in transit",
      "terms": ["TLS_1_2", "TLSv1.2", "https://", "wss://", "ssl_ctx"]
    },
    {
      "id": "CC6.8", "title": "Encryption of data at rest",
      "imports": ["crypto-js", "node-forge", "cryptography"],
      "terms": ["AES-256", "AES_256", "encrypt_at_rest"]
    },
    {
      "id": "CC7.1", "title": "Security monitoring + alerting wired in",
      "manifest_deps": ["@sentry/node", "datadog-metrics", "newrelic", "elastic-apm-node"],
      "imports": ["@sentry/node", "newrelic", "datadog"]
    },
    {
      "id": "CC7.2", "title": "Anomaly detection / WAF / IDS",
      "manifest_deps": ["express-rate-limit", "helmet", "fastify-helmet"],
      "imports": ["helmet", "express-rate-limit"]
    },
    {
      "id": "CC7.3", "title": "Incident response runbook + paging",
      "paths": ["**/RUNBOOK.md", "**/INCIDENT_RESPONSE.md", "**/runbooks/**"]
    },
    {
      "id": "CC8.1", "title": "Change management — code review + CI gates",
      "paths": [".github/workflows/*", "**/.github/CODEOWNERS", "**/PULL_REQUEST_TEMPLATE*"]
    },
    {
      "id": "CC9.1", "title": "Risk assessment artifacts",
      "paths": ["**/THREAT_MODEL.md", "**/risk-assessment*", "**/RISK*.md"]
    },
    {
      "id": "CC9.2", "title": "Vendor risk management — SBOM available",
      "paths": ["**/sbom*.json", "**/cyclonedx*.json", "**/spdx*.json"]
    }
  ]
}
